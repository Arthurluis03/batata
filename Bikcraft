//////////////////
style.css
@import url('layout/global.css');
@import url('layout/footer.css');
@import url('layout/header.css');
@import url('layout/main.css');
@import url('layout/section.css');
//////////////////


SECTION 

section {
    margin: 0 auto;
    max-width: 1000px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    align-items: center;
    margin-bottom: 40px;

}
section > h1 {
    font-size: 64px;
    color:  #c6c6c6;
    text-transform: uppercase;
    text-align: right;
    padding: 40px ;
}
section > ul  {
    list-style: none;
    display: grid;
    gap: 10px;
    padding: 10px 22px;

}
section  ul  li {
    display: grid;
    gap: 10px;
    padding: 20px 32px;
    background-color: #fff;
}
section ul li h2 
{   
    text-transform: uppercase;
    font-size: 20px;
    font-weight: 500;
    grid-column: 1;
}
section ul li p {
    grid-column: 1;  
    font-size: 20px;
}



///////////////////



FOOTER 

footer{
    padding: 25px;
    background-color: #fff;
    text-align: center;
}
footer p {
    text-transform: capitalize;
    font-size: 14px;
}



////////////////////////////////
 GLOBAL 

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;

}
body {
    background-color: #f7f7f7;
    font-family: Arial, Helvetica, sans-serif;
}
img {
    display: block;
    max-width: 100%;
}

/////////////////////////



 HEADER

header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding-top: 30px;   
}

header nav .list {
    display: flex;
    gap: 50px;
    list-style: none;
    text-decoration: none;
    
}

.list li {
    background-color: #fff;
}
.list li a {
    display: block;
    text-transform: capitalize;
    color: #000;
    padding: 6px 6px;
    font-size: 18px;
    text-decoration:  none;


}
////////////////////////
MAIN 


main {
    display:  grid;
    grid-template-columns: repeat(2, 1fr);
    max-width: 1000px;
    margin: 100px auto;
    
}
main .left {
    display: grid;
    align-content: center;
    justify-items: end;
    padding: 16px 32px;

}

.left p {
    font-size: 18px;
    text-align: right;
}

.left a {
    background-color: #ff0000;
    color: #fff;
    text-decoration: none;
    padding: 16px 32px;
    font-weight: 500;
    text-transform: uppercase;
    border-radius: 10px;
    margin-top: 10px;
}


