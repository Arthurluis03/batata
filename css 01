<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Grid</title>
    <style>
        .grid-container {
            background-color: white;
            display: grid;
            height: 100vh;
            grid-template-columns: repeat(2, 200px);
            grid-auto-rows: minmax(7px, 7%);
            gap: 15px;
            justify-content: center;
        }

        .items {
            background-color: darkgray;
        }

        .item1{
            grid-column: 1/3;
        }
        .item2{
            grid-row: 2/7;
        }
        .item3{
            grid-row: 2/5;
        }
        .item4{
            grid-row: 5/7;
        }
        .item5{
            grid-column: 1/3;
            grid-row: 7/9;
        }
        .item6{
            grid-row: 9/11;
        }
        .item7{
            grid-row: 11/13;
        }
        .item8{
            grid-row: 9/13;
        }
        .item9{
            grid-column: 1/3;
        }
        
    </style>
</head>
<body>
    <div class="grid-container">
        <div class="items item1">
            1
        </div>
        <div class="items item2">
        2
        </div>
        <div class="items item3">
        3
            </div>
